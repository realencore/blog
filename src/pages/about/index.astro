---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
---

<BaseLayout title="关于" bodyClass="about-page">
  <div class="page-header page-header--about">
    <h1 class="page-title">关于</h1>
    <div class="page-actions">
      <a
        class="icon-link"
        href="https://x.com/fudimeng"
        aria-label="Twitter"
        title="Twitter"
      >
        <Icon name="x-twitter" class="icon" />
      </a>
    </div>
  </div>
  <p class="about-intro-line">
    资深 IT 民工<br />
    骨灰级互联网产品爱好者<br />
    正在练习写好看的硬笔字
  </p>

  <h2 class="section-title about-section-title">联系</h2>
  <section class="contact-block" aria-label="联系方式">
    <p class="contact-note"></p>
    <ul class="contact-list">
      <li>
        <span class="contact-link-head">
          <Icon name="mail" class="contact-icon" />
          <span>Email：</span>
        </span>
        <a href="mailto:qingye411@gmail.com">qingye411@gmail.com</a>
      </li>
    </ul>
  </section>

</BaseLayout>
